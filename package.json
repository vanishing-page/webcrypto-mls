{
  "name": "@vanishing.page/webcrypto-mls",
  "version": "0.0.2",
  "description": "MLS in the browser",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./*": {
      "import": {
        "types": "./dist/*.d.ts",
        "default": "./dist/*.js"
      },
      "require": {
        "types": "./dist/*.d.cts",
        "default": "./dist/*.cjs"
      }
    }
  },
  "main": "dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "./dist/*"
  ],
  "scripts": {
    "lint": "eslint \"./**/*.{ts,js}\"",
    "test": "npm run test:node",
    "test:node": "esbuild ./test/index.ts --bundle --platform=node --format=cjs --loader:.json=json --keep-names --outfile=.test-bundle.cjs && node .test-bundle.cjs && rm .test-bundle.cjs",
    "test:browser": "node build-test.js | tapout --timeout 300000",
    "build-cjs": "esbuild src/*.ts --format=cjs --keep-names --tsconfig=tsconfig.build.json --outdir=./dist --out-extension:.js=.cjs --sourcemap",
    "build-cjs:min": "esbuild src/*.ts --format=cjs --minify --keep-names --tsconfig=tsconfig.build.json --outdir=./dist --out-extension:.js=.min.cjs --sourcemap",
    "build-esm": "esbuild src/*.ts --format=esm --metafile=dist/meta.json --keep-names --tsconfig=tsconfig.build.json --outdir=./dist --sourcemap && tsc --emitDeclarationOnly --project tsconfig.build.json --outDir dist",
    "build-esm:min": "esbuild ./src/*.ts --format=esm --keep-names --bundle --tsconfig=tsconfig.build.json --minify --out-extension:.js=.min.js --outdir=./dist --sourcemap",
    "build-types-cjs": "node scripts/emit-cts.mjs",
    "build-example": "mkdir -p ./public && rm -rf ./public/* && vite --mode staging --base=\"/webcrypto-mls\" build",
    "build-docs": "typedoc ./src/index.ts",
    "build": "mkdir -p ./dist && rm -rf ./dist/* && npm run build-cjs && npm run build-esm && npm run build-types-cjs && npm run build-esm:min && npm run build-cjs:min",
    "start": "vite",
    "toc": "markdown-toc --maxdepth 3 -i README.md",
    "preversion": "npm run lint",
    "version": "npm run toc && auto-changelog -p --template keepachangelog --breaking-pattern 'BREAKING CHANGE:' && git add CHANGELOG.md README.md",
    "postversion": "git push --follow-tags && npm publish",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@hpke/chacha20poly1305": "^1.8.0",
    "@hpke/core": "^1.9.0",
    "@noble/ciphers": "^2.2.0",
    "@noble/hashes": "^2.2.0"
  },
  "devDependencies": {
    "@esbuild-plugins/node-globals-polyfill": "^0.2.3",
    "@hpke/hybridkem-x-wing": "^0.6.1",
    "@hpke/ml-kem": "^0.2.1",
    "@noble/curves": "^2.0.1",
    "@noble/post-quantum": "^0.5.2",
    "@preact/preset-vite": "^2.10.2",
    "@preact/signals": "^2.3.2",
    "@substrate-system/debug": "^0.9.67",
    "@substrate-system/tapout": "^0.0.40",
    "@substrate-system/tapzero": "^0.10.16",
    "auto-changelog": "^2.4.0",
    "browserslist": "^4.28.6",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "events": "^3.3.0",
    "htm": "^3.1.1",
    "lightningcss": "^1.32.0",
    "markdown-toc": "^1.2.0",
    "newneostandard": "^0.14.1",
    "preact": "^10.27.0",
    "typedoc": "^0.28.9",
    "typescript": "^5.9.2",
    "vite": "^7.0.6"
  },
  "directories": {
    "example": "example",
    "test": "test"
  },
  "keywords": [
    "webcrypto",
    "MLS",
    "browser",
    "cryptography",
    "encryption"
  ],
  "homepage": "https://github.com/vanishing-page/webcrypto-mls",
  "bugs": {
    "url": "https://github.com/vanishing-page/webcrypto-mls/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vanishing-page/webcrypto-mls.git"
  },
  "author": "nichoth <nichoth@nichoth.com> (https://nichoth.com)",
  "license": "SEE LICENSE IN LICENSE"
}
